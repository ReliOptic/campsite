#!/usr/bin/env bash
set -euo pipefail

# --- Path resolution ---
# 1. CAMPSITE_HOME env var  2. ~/.campsite/  3. script-relative (dev mode)
_resolve_root() {
    if [[ -n "${CAMPSITE_HOME:-}" && -d "$CAMPSITE_HOME/lib" ]]; then
        printf '%s' "$CAMPSITE_HOME"
    elif [[ -d "$HOME/.campsite/lib" ]]; then
        printf '%s' "$HOME/.campsite"
    else
        local script_dir
        script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
        printf '%s' "$(cd "$script_dir/.." && pwd)"
    fi
}

CAMPSITE_ROOT="$(_resolve_root)"
CAMPSITE_LIB="$CAMPSITE_ROOT/lib"
CAMPSITE_TEMPLATES="$CAMPSITE_ROOT/templates"

# --- Source libraries ---
source "$CAMPSITE_LIB/compat.sh"
source "$CAMPSITE_LIB/common.sh"
source "$CAMPSITE_LIB/detect.sh"
source "$CAMPSITE_LIB/lock.sh"
source "$CAMPSITE_LIB/hash.sh"
source "$CAMPSITE_LIB/security.sh"
source "$CAMPSITE_LIB/compile.sh"
source "$CAMPSITE_LIB/history.sh"
source "$CAMPSITE_LIB/ui.sh"
source "$CAMPSITE_LIB/camp.sh"
source "$CAMPSITE_LIB/camp-assets.sh"
source "$CAMPSITE_LIB/collector.sh"
source "$CAMPSITE_LIB/agent.sh"
source "$CAMPSITE_LIB/firestate.sh"

# --- Load defaults ---
if [[ -f "$CAMPSITE_ROOT/config/defaults.sh" ]]; then
    source "$CAMPSITE_ROOT/config/defaults.sh"
fi
# Load user overrides
local_global="$(campsite_global_dir)"
if [[ -f "$local_global/user/config.sh" ]]; then
    source "$local_global/user/config.sh"
fi

# ============================================================
# Commands
# ============================================================

usage() {
    local version
    version="$(cat "$CAMPSITE_ROOT/VERSION" 2>/dev/null || cat "$CAMPSITE_ROOT/version" 2>/dev/null || echo "dev")"
    cat <<EOF
campsite $version — project state compiler for AI coding agents

usage:
  campsite                Interactive launcher
  campsite setup          First-run guided setup
  campsite init [path]    Bootstrap a new campsite project
  campsite sync           Compile source of truth → agent context files
  campsite save           Verify updates + cleanup + unlock
  campsite save --push    Create and push a safe checkpoint commit
  campsite status         Current project state summary
  campsite peek           View active session from another terminal
  campsite go [name|#]    Jump to recent project (cd + optional sync)
  campsite validate       Structure + freshness verification
  campsite recover        Clear orphaned locks + stale files
  campsite dashboard      All projects overview
  campsite camp           Camp state commands and local recovery-first scene
  campsite camp render    Render camp in browser (Phaser storyworld when built, legacy HTML otherwise)
  campsite camp render --legacy   Force legacy HTML renderer
  campsite camp serve     Live camp server with auto-refresh (http://localhost:8470)
  campsite camp serve --legacy    Force legacy HTML server
  campsite workspace set <path>   Set workspace root

  campsite export         Export camp state as JSON to stdout (also writes .campsite/camp/camp.json)
  campsite export --json  Same as above (explicit flag)

  campsite --version      Print version
  campsite help           Show this message
EOF
}

# --- campsite (no args) — interactive launcher ---
cmd_launcher() {
    launcher  # from ui.sh — sets SELECTED_PROJECT, SELECTED_AGENT

    local project="$SELECTED_PROJECT"
    local agent="$SELECTED_AGENT"
    local device
    device="$(detect_device)"
    local terminal_name
    terminal_name="$(detect_terminal_surface)"

    # Validate
    _validate_project "$project" quiet

    # Hash integrity check
    if ! hash_compare "$project" 2>/dev/null; then
        local rc=$?
        if [[ $rc -eq 1 ]]; then
            warn "source files changed since last campsite sync"
            ui_confirm "Accept changes and continue?" || exit 1
        fi
    fi

    # Lock
    lock_acquire "$project" "${USER:-unknown}" "$agent"

    # Compile
    local compiled_file
    compiled_file="$(compile_context "$project" "$agent")"
    info "context compiled → $(basename "$compiled_file")"
    camp_register_sync "$project" "$agent"

    # Store entry hash
    local entry_hash
    entry_hash="$(hash_compute "$project")"
    local session_outcome="normal"
    local session_participant_id
    session_participant_id="$(camp_session_start "$project" "$agent" "$$" "$terminal_name")"

    # Banner
    ui_banner "$project" "$agent" "$device"
    info "launching $agent..."
    printf '\n'

    # Trap for cleanup on exit
    local start_time
    start_time="$(date +%s)"

    _session_cleanup() {
        local end_time
        end_time="$(date +%s)"
        local duration=$(( end_time - start_time ))
        local outcome="normal"

        # Check if source files were updated
        local current_hash
        current_hash="$(hash_compute "$project" 2>/dev/null || echo "")"
        local state_changed=0
        if [[ "$current_hash" == "$entry_hash" ]]; then
            printf '\n'
            warn "status.md/handoff.md unchanged during session"
            warn "consider updating before your next session"
        else
            state_changed=1
        fi

        camp_session_finish "$project" "$agent" "$$" "$session_outcome" "$state_changed" 2>/dev/null || true

        # Cleanup compiled file
        compile_cleanup "$project" "$agent" 2>/dev/null || true

        # Release lock
        lock_release "$project" 2>/dev/null || true

        # Record history
        history_append "$project" "$agent" "$device" "$(now_iso)" "$duration" "$outcome" 2>/dev/null || true
    }
    trap _session_cleanup EXIT

    # Get agent command from adapter
    adapter_load "$agent"
    local agent_cmd="$ADAPTER_COMMAND"

    # Launch agent with lifecycle monitoring (not exec — so trap works)
    cd "$project"
    agent_launch "$project" "$agent" "$agent_cmd" || session_outcome="error"
}

# --- campsite init [path] ---
cmd_init() {
    local project_root="${1:-$PWD}"
    project_root="$(resolve_path "$project_root")"

    local slug
    slug="$(slug_from_path "$project_root")"
    local title
    title="$(basename "$project_root")"
    local today
    today="$(today_date)"

    mkdir -p "$project_root"/{scripts,docs,src,tests,deploy}
    mkdir -p "$project_root/.campsite"

    # Render templates
    _render_if_missing() {
        local src="$1" dst="$2"
        if [[ ! -e "$dst" ]]; then
            if [[ ! -f "$src" ]]; then
                warn "template not found: $src (skipping)"
                return 1
            fi
            sed \
                -e "s/project-name/$slug/g" \
                -e "s/Project Name/$title/g" \
                -e "s/yyyy-mm-dd/$today/g" \
                "$src" > "$dst" || {
                    warn "failed to render template: $src"
                    return 1
                }
        fi
    }

    _render_if_missing "$CAMPSITE_TEMPLATES/README.md.template"               "$project_root/README.md"
    _render_if_missing "$CAMPSITE_TEMPLATES/status.md.template"               "$project_root/status.md"
    _render_if_missing "$CAMPSITE_TEMPLATES/handoff.md.template"              "$project_root/handoff.md"
    _render_if_missing "$CAMPSITE_TEMPLATES/decisions.md.template"            "$project_root/decisions.md"
    _render_if_missing "$CAMPSITE_TEMPLATES/gitignore.template"               "$project_root/.gitignore"
    _render_if_missing "$CAMPSITE_TEMPLATES/project-bootstrap.sh.template"    "$project_root/scripts/bootstrap.sh"

    [[ -f "$project_root/scripts/bootstrap.sh" ]] && chmod +x "$project_root/scripts/bootstrap.sh"

    # Install git post-commit hook for automatic signal collection
    collector_install_git_hook "$project_root"
    collector_ensure_store "$project_root"
    collector_record_event "$project_root" "init" "Project initialized" "campsite"

    info "project initialized: $project_root"
}

# --- campsite sync [--adapter=name] ---
cmd_sync() {
    local specific_adapter=""

    # Parse args
    for arg in "$@"; do
        case "$arg" in
            --adapter=*) specific_adapter="${arg#--adapter=}" ;;
            *) ;;
        esac
    done

    local project
    project="$(detect_project)"

    _validate_project "$project" quiet

    # Hash integrity check
    local hash_rc=0
    hash_compare "$project" 2>/dev/null || hash_rc=$?
    if [[ $hash_rc -eq 1 ]]; then
        warn "source files changed since last campsite save"
        ui_confirm "Accept changes?" || exit 1
    fi

    if [[ -n "$specific_adapter" ]]; then
        local compiled
        compiled="$(compile_context "$project" "$specific_adapter")"
        info "compiled → $(basename "$compiled")"
        camp_register_sync "$project" "$specific_adapter"
    else
        # Compile for all adapters whose command is in PATH
        local count=0
        while IFS= read -r adapter_name; do
            local adapter_file
            adapter_file="$(_adapter_find "$adapter_name" 2>/dev/null)" || continue
            local cmd
            cmd="$(field_value_plain "$adapter_file" "command")"
            if command -v "$cmd" >/dev/null 2>&1; then
                local compiled
                compiled="$(compile_context "$project" "$adapter_name")"
                info "compiled → $(basename "$compiled")"
                camp_register_sync "$project" "$adapter_name"
                count=$((count + 1))
            fi
        done < <(adapter_list 2>/dev/null)

        if [[ $count -eq 0 ]]; then
            warn "no agent commands found in PATH"
            printf "  Install one of: claude, codex, gemini, copilot, cursor\n" >&2
            printf "  Or compile for a specific adapter: campsite sync --adapter=claude\n" >&2
        fi
    fi

    # Capture git snapshot + record sync event
    collector_git_snapshot "$project" 2>/dev/null || true
    collector_record_event "$project" "sync" "Context compiled for ${specific_adapter:-all} adapters" "campsite" 2>/dev/null || true

    # Store hash + sync state (git HEAD snapshot for crash recovery)
    hash_store "$project"
    sync_state_save "$project" 2>/dev/null || true
    info "hash stored"

    # Brief camp context after sync
    local sync_mission
    sync_mission="$(field_value "$project/handoff.md" "task" 2>/dev/null || echo "")"
    [[ -z "$sync_mission" ]] || printf "  mission: %s\n" "$sync_mission"

    # Register in history so 'campsite go' works from first sync
    local sync_adapter_name="${specific_adapter:-unknown}"
    local sync_device
    sync_device="$(detect_device 2>/dev/null || echo "unknown")"
    history_append "$project" "$sync_adapter_name" "$sync_device" "$(now_iso)" "0" "sync"
}

_checkpoint_commit_message() {
    local project="$1"
    local phase task
    phase="$(field_value "$project/status.md" "phase" 2>/dev/null || echo "checkpoint")"
    task="$(field_value "$project/handoff.md" "task" 2>/dev/null || echo "update project state")"
    printf 'checkpoint: %s - %s' "$phase" "$task"
}

_git_repo_root() {
    local project="$1"
    git -C "$project" rev-parse --show-toplevel 2>/dev/null || return 1
}

_save_git_checkpoint_push() {
    local project="$1"
    local repo_root branch
    repo_root="$(_git_repo_root "$project")" || {
        warn "save --push skipped: project is not inside a git repository"
        return 0
    }

    branch="$(git -C "$repo_root" branch --show-current 2>/dev/null || echo "")"
    [[ -n "$branch" ]] || branch="master"

    git -C "$repo_root" add -u || return 1
    if ! git -C "$repo_root" diff --cached --quiet --exit-code; then
        local message
        message="$(_checkpoint_commit_message "$project")"
        git -C "$repo_root" commit -m "$message" >/dev/null || return 1
        info "checkpoint committed"
    else
        info "no tracked git changes to checkpoint"
    fi

    git -C "$repo_root" push origin "$branch"
    info "checkpoint pushed → origin/$branch"
}

# --- campsite save ---
cmd_save() {
    local do_push="${CAMPSITE_SAVE_PUSH:-0}"
    for arg in "$@"; do
        case "$arg" in
            --push) do_push=1 ;;
            *) fail "unknown flag for campsite save: $arg" "Valid flags: --push" ;;
        esac
    done

    local project
    project="$(detect_project)"

    # Credential scan
    if ! scan_project_files "$project" 2>/dev/null; then
        warn "potential credentials detected in source files"
        ui_confirm "Continue anyway?" || exit 1
    fi

    # Hash comparison
    local hash_rc=0
    hash_compare "$project" 2>/dev/null || hash_rc=$?
    if [[ $hash_rc -eq 0 ]]; then
        warn "source files unchanged since last sync — did you update status.md/handoff.md?"
    fi
    local state_changed=0
    [[ $hash_rc -eq 1 ]] && state_changed=1

    camp_sync_mission_from_project "$project"
    camp_capture_locked_session_on_save "$project" "$state_changed" 2>/dev/null || true

    # Record save event + file activity
    collector_file_activity "$project" 2>/dev/null || true
    collector_record_event "$project" "save" "Project state saved" "user" 2>/dev/null || true

    # Cleanup compiled files
    compile_cleanup_all "$project"
    info "compiled files cleaned"

    # Release lock
    if lock_is_held "$project" 2>/dev/null; then
        lock_release "$project" 2>/dev/null || true
        info "lock released"
    fi

    # Store current hash
    hash_store "$project"
    printf '\n'
    printf '  \033[32m◎\033[0m  좋아요! 다음에 돌아오면 바로 시작할 수 있어요.\n'

    # Brief camp state after save
    local next_val=""
    while IFS=$'\t' read -r label value; do
        case "$label" in
            NEXT) next_val="$value" ;;
        esac
    done < <(camp_overview_lines "$project" 2>/dev/null)
    if [[ -n "$next_val" ]]; then
        printf '     next-move: %s\n' "$next_val"
    fi
    printf '\n'

    if [[ "$do_push" == "1" ]]; then
        _save_git_checkpoint_push "$project"
    fi
}

# --- campsite status ---
cmd_status() {
    local project
    project="$(detect_project)"

    local name
    name="$(basename "$project")"
    local phase
    phase="$(field_value "$project/status.md" "phase" 2>/dev/null || echo "?")"
    local confidence
    confidence="$(field_value "$project/status.md" "confidence" 2>/dev/null || echo "?")"
    local last_updated
    last_updated="$(field_value "$project/status.md" "last-updated" 2>/dev/null || echo "?")"
    local last_agent
    last_agent="$(field_value "$project/status.md" "last-agent" 2>/dev/null || echo "?")"
    local last_device
    last_device="$(field_value "$project/status.md" "last-device" 2>/dev/null || echo "?")"
    local freshness_level
    freshness_level="$(freshness_level_for_file "$project/status.md")"
    local freshness_label
    freshness_label="$(freshness_label_for_file "$project/status.md")"

    local task
    task="$(field_value "$project/handoff.md" "task" 2>/dev/null || echo "?")"

    # Derive fire state from real signals
    local fire_state fire_label
    fire_state="$(firestate_derive "$project" 2>/dev/null || echo "deungbul")"
    fire_label="$(firestate_label_ko "$fire_state")"

    printf '\n'
    printf "  ${_C_BOLD:-}%s${_C_RESET:-}\n" "$name"
    printf "  fire:             %s\n" "$fire_label"
    printf "  mission:          %s\n" "$task"
    printf '\n'

    # Camp state — information hierarchy: alive → needs-me → next
    while IFS=$'\t' read -r label value; do
        case "$label" in
            ACTIVE)  printf "  working-now:      %s\n" "$value" ;;
            WAITING) printf "  waiting-on-you:   %s\n" "$value" ;;
            NEXT)    printf "  next-move:        %s\n" "$value" ;;
        esac
    done < <(camp_overview_lines "$project")
    printf '\n'

    # Operational metadata
    printf "  phase:            %s\n" "$phase"
    printf "  confidence:       %s\n" "$confidence"
    printf "  freshness:        %s (%s)\n" "$freshness_level" "$freshness_label"
    printf "  last-updated:     %s\n" "$last_updated"
    printf "  last-agent:       %s\n" "$last_agent"
    printf "  last-device:      %s\n" "$last_device"

    # Lock
    if lock_is_held "$project" 2>/dev/null; then
        local lock_file
        lock_file="$(lock_path "$project")"
        local held_by
        held_by="$(field_value_plain "$lock_file" "actor" 2>/dev/null || echo "?")"
        local held_tool
        held_tool="$(field_value_plain "$lock_file" "tool" 2>/dev/null || echo "?")"
        printf "  lock:             ${_C_RED:-}locked${_C_RESET:-} by %s (%s)\n" "$held_by" "$held_tool"
    else
        printf "  lock:             ${_C_GREEN:-}unlocked${_C_RESET:-}\n"
    fi

    # Hash
    local hash_rc=0
    hash_compare "$project" 2>/dev/null || hash_rc=$?
    case $hash_rc in
        0) printf "  integrity:        ${_C_GREEN:-}clean${_C_RESET:-}\n" ;;
        1) printf "  integrity:        ${_C_YELLOW:-}changed${_C_RESET:-} (modified since last sync)\n" ;;
        2) printf "  integrity:        ${_C_DIM:-}no baseline${_C_RESET:-} (run campsite sync)\n" ;;
    esac
    printf '\n'
}

# --- campsite validate ---
cmd_validate() {
    local project
    project="$(detect_project)"
    _validate_project "$project" verbose
    info "valid: $(basename "$project")"
}

_validate_project() {
    local project="$1"
    local mode="${2:-verbose}"

    # Required files
    for file in README.md status.md handoff.md decisions.md; do
        [[ -f "$project/$file" ]] || fail "missing: $project/$file" \
            "Run 'campsite init' to scaffold project files"
    done

    # Header checks
    grep -q "^# Status" "$project/status.md" || fail "invalid status.md header"
    grep -q "^# Handoff" "$project/handoff.md" || fail "invalid handoff.md header"

    # Phase validation
    local phase
    phase="$(field_value "$project/status.md" "phase")"
    [[ -n "$phase" ]] || fail "missing status phase"
    
    local valid_phases="${CAMPSITE_VALID_PHASES:-discovery building testing reviewing blocked deployed}"
    local phase_valid=0
    local p
    for p in $valid_phases; do
        [[ "$p" == "$phase" ]] && { phase_valid=1; break; }
    done
    [[ $phase_valid -eq 1 ]] || fail "invalid phase: $phase" "Valid: $valid_phases"

    # Task validation
    local task
    task="$(field_value "$project/handoff.md" "task")"
    [[ -n "$task" ]] || fail "empty handoff task"

    # Freshness check
    if [[ "$mode" == "verbose" ]]; then
        local status_freshness handoff_freshness
        status_freshness="$(freshness_level_for_file "$project/status.md")"
        handoff_freshness="$(freshness_level_for_file "$project/handoff.md")"
        if [[ "$status_freshness" == "stale" ]]; then
            warn "status.md is $(freshness_label_for_file "$project/status.md")"
        fi
        if [[ "$handoff_freshness" == "stale" ]]; then
            warn "handoff.md is $(freshness_label_for_file "$project/handoff.md")"
        fi
    fi
}

# --- campsite recover ---
cmd_recover() {
    local workspace=""
    workspace="$(detect_workspace 2>/dev/null)" || true

    if [[ -z "$workspace" ]]; then
        # Try current project only
        local project
        project="$(detect_project 2>/dev/null)" || fail "no project or workspace found"
        _recover_project "$project"
        return
    fi

    local found=0
    while IFS= read -r project; do
        _recover_project "$project" && found=$((found + 1))
    done < <(detect_all_projects "$workspace" 2>/dev/null || true)

    if [[ $found -eq 0 ]]; then
        info "all projects healthy — no recovery needed"
    fi
}

_recover_project() {
    local project="$1"
    local name
    name="$(basename "$project")"
    local recovered=0
    local had_crash=0

    # Check for orphaned lock (= crash indicator)
    if [[ -f "$(lock_path "$project")" ]]; then
        if lock_check_orphan "$project"; then
            local lock_file tool_at_crash
            lock_file="$(lock_path "$project")"
            tool_at_crash="$(field_value_plain "$lock_file" "tool" 2>/dev/null || echo "?")"

            printf '\n'
            printf "  ${_C_YELLOW:-}⚠${_C_RESET:-}  ${_C_BOLD:-}%s${_C_RESET:-} — abnormal termination detected\n" "$name"
            printf "  agent: %s\n" "$tool_at_crash"

            rm -f "$(lock_path "$project")"
            printf "  ${_C_GREEN:-}✓${_C_RESET:-} orphaned lock cleared\n"
            had_crash=1
            recovered=$((recovered + 1))
        fi
    fi

    # Check for stale compiled files without active lock
    if ! lock_is_held "$project" 2>/dev/null; then
        local cleaned=0
        while IFS= read -r adapter_name; do
            if compile_cleanup "$project" "$adapter_name" 2>/dev/null; then
                cleaned=$((cleaned + 1))
            fi
        done < <(adapter_list 2>/dev/null || true)
        if [[ $cleaned -gt 0 ]]; then
            printf "  ${_C_GREEN:-}✓${_C_RESET:-} %d compiled file(s) cleaned\n" "$cleaned"
            recovered=$((recovered + 1))
        fi
    fi

    # Show crash recovery info: what changed during the dead session
    if [[ $had_crash -eq 1 ]]; then
        printf '\n'
        sync_state_show "$project" 2>/dev/null || true
        printf '\n'
        printf "  ${_C_BOLD:-}recommended actions:${_C_RESET:-}\n"
        printf "    1. review changes above (git diff, git log)\n"
        printf "    2. update status.md, handoff.md\n"
        printf "    3. campsite save\n"
        printf '\n'
    elif [[ $recovered -eq 0 ]]; then
        info "$name: no recovery needed"
    fi

    return $(( recovered > 0 ? 0 : 1 ))
}

# --- campsite dashboard ---
cmd_dashboard() {
    local workspace=""
    workspace="$(detect_workspace 2>/dev/null)" || true

    if [[ -z "$workspace" ]]; then
        fail "no workspace found" \
            "Run 'campsite setup' or 'campsite workspace set <path>'"
    fi

    printf '\n'
    printf "  ${_C_BOLD:-}campsite dashboard${_C_RESET:-}\n"
    printf "  %s\n\n" "$workspace"

    printf "  %-20s │ %-10s │ %-10s │ %-12s │ %s\n" "PROJECT" "PHASE" "CONFIDENCE" "LOCK" "NEXT"
    printf "  %-20s─┼─%-10s─┼─%-10s─┼─%-12s─┼─%s\n" "────────────────────" "──────────" "──────────" "────────────" "────────────────"

    while IFS= read -r project; do
        local name
        name="$(basename "$project")"
        local phase
        phase="$(field_value "$project/status.md" "phase" 2>/dev/null || echo "?")"
        local confidence
        confidence="$(field_value "$project/status.md" "confidence" 2>/dev/null || echo "?")"
        local task
        task="$(field_value "$project/handoff.md" "task" 2>/dev/null || echo "?")"
        # Truncate task to 40 chars
        [[ ${#task} -gt 40 ]] && task="${task:0:37}..."

        local lock_status
        if lock_is_held "$project" 2>/dev/null; then
            local held_tool
            held_tool="$(field_value_plain "$(project_campsite_dir "$project")/lock" "tool" 2>/dev/null || echo "?")"
            lock_status="${_C_RED:-}locked${_C_RESET:-}($held_tool)"
        elif [[ -f "$(lock_path "$project")" ]]; then
            lock_status="${_C_YELLOW:-}orphaned${_C_RESET:-}"
        else
            lock_status="${_C_GREEN:-}free${_C_RESET:-}"
        fi

        printf "  %-20s │ %-10s │ %-10s │ %-12b │ %s\n" \
            "$name" "$phase" "$confidence" "$lock_status" "$task"
    done < <(detect_all_projects "$workspace" 2>/dev/null)

    printf '\n'
}

_camp_write_json() {
    local project_root="$1" output="$2"
    local working_now="" waiting_on_you="" next_move="" participant_count
    participant_count="$(camp_participant_count "$project_root")"
    while IFS=$'\t' read -r label value; do
        case "$label" in
            ACTIVE) working_now="$value" ;;
            WAITING) waiting_on_you="$value" ;;
            NEXT) next_move="$value" ;;
        esac
    done < <(camp_overview_lines "$project_root")
    local mission
    mission="$(camp_field_get "$(camp_mission_path "$project_root")" "title")"
    local participants_file
    participants_file="$(camp_participants_path "$project_root")"
    local pjson=""
    if [[ -f "$participants_file" ]]; then
        pjson="$(awk -F'\t' '
            function esc(s) { gsub(/\\/, "\\\\", s); gsub(/"/, "\\\"", s); gsub(/\n/, " ", s); return s }
            NR == 1 { next }
            {
                if (NR > 2) printf ","
                printf "{\"name\":\"%s\",\"state\":\"%s\",\"summary\":\"%s\",\"blocker\":\"%s\",\"next\":\"%s\",\"tool\":\"%s\",\"terminal\":\"%s\"}",
                    esc($2), esc($6), esc($7), esc($8), esc($9), esc($4), esc($5)
            }
        ' "$participants_file")"
    fi
    cat > "$output" <<JSONEOF
{
  "mission": "$(printf '%s' "$mission" | sed 's/"/\\"/g')",
  "working_now": "$(printf '%s' "$working_now" | sed 's/"/\\"/g')",
  "waiting_on_you": "$(printf '%s' "$waiting_on_you" | sed 's/"/\\"/g')",
  "next_move": "$(printf '%s' "$next_move" | sed 's/"/\\"/g')",
  "participant_count": "$participant_count",
  "participants": [${pjson}],
  "updated_at": "$(now_iso)"
}
JSONEOF
}

# --- campsite camp ---
cmd_camp() {
    local project
    project="$(detect_project)"
    _validate_project "$project" quiet
    camp_ensure_store "$project"

    local subcommand="${1:-render}"
    shift || true

    case "$subcommand" in
        render)
            local no_open=0
            local print_path=0
            local legacy=0
            for arg in "$@"; do
                case "$arg" in
                    --no-open)    no_open=1 ;;
                    --print-path) print_path=1 ;;
                    --legacy)     legacy=1 ;;
                    *) fail "unknown flag for campsite camp render: $arg" "Valid flags: --no-open, --print-path, --legacy" ;;
                esac
            done

            local html_path
            # Use Phaser renderer when dist exists and --legacy not requested.
            local _phaser_dist
            _phaser_dist="$(camp_phaser_dist_dir 2>/dev/null)" || _phaser_dist=""
            if [[ $legacy -eq 0 && -n "$_phaser_dist" ]]; then
                if ! html_path="$(camp_render_phaser "$project" 2>&1)"; then
                    warn "Phaser render failed — falling back to legacy renderer"
                    html_path="$(camp_render "$project")"
                fi
            else
                html_path="$(camp_render "$project")"
            fi

            if [[ $print_path -eq 1 ]]; then
                printf '%s\n' "$html_path"
                return 0
            fi

            info "camp rendered → $html_path"
            if [[ $no_open -eq 1 ]]; then
                return 0
            fi

            if camp_open_browser "$html_path"; then
                info "opened in browser"
            else
                warn "could not open a browser automatically"
                printf '%s\n' "$html_path"
            fi
            ;;
        serve)
            local port="${CAMPSITE_SERVE_PORT:-8470}"
            local legacy=0
            for arg in "$@"; do
                case "$arg" in
                    --port=*) port="${arg#--port=}" ;;
                    --legacy)  legacy=1 ;;
                    *) fail "unknown flag for campsite camp serve: $arg" "Valid flags: --port=N, --legacy" ;;
                esac
            done

            local camp_d
            camp_d="$(camp_dir "$project")"

            # Determine serve directory and render initial output
            local serve_dir
            local _phaser_dist_s
            _phaser_dist_s="$(camp_phaser_dist_dir 2>/dev/null)" || _phaser_dist_s=""
            if [[ $legacy -eq 0 && -n "$_phaser_dist_s" ]]; then
                # Phaser path: copy dist + inject CAMP_STATE + get serve dir
                if serve_dir="$(camp_render_phaser_serve "$project" 2>&1)"; then
                    info "using Phaser storyworld renderer"
                else
                    warn "Phaser serve setup failed — falling back to legacy renderer"
                    legacy=1
                fi
            fi

            if [[ $legacy -eq 1 || -z "${serve_dir:-}" ]]; then
                # Legacy path
                camp_render "$project" >/dev/null

                # Copy exported design assets if available
                if camp_assets_install "$project" 2>/dev/null; then
                    info "design assets installed to $camp_d/assets/"
                fi

                # Generate camp-state.json for live polling
                _camp_write_json "$project" "$camp_d/camp-state.json"

                # Inject live-reload script into rendered HTML
                local html_path_legacy
                html_path_legacy="$(camp_index_path "$project")"
                if ! grep -q 'camp-live-poll' "$html_path_legacy" 2>/dev/null; then
                    _portable_sed_i 's|</body>|<script id="camp-live-poll">setInterval(async()=>{try{const r=await fetch("camp-state.json?t="+Date.now());if(!r.ok)return;const d=await r.json();document.getElementById("working-now").textContent=d.working_now;document.getElementById("waiting-on-you").textContent=d.waiting_on_you;document.getElementById("next-move").textContent=d.next_move;document.getElementById("camp-footer").textContent=d.participant_count+" participants in camp";if(d.participants){const sl={bulssi:"불씨",modakbul:"모닥불",deungbul:"등불",yeongi:"연기",jangjak:"장작"};const l=document.getElementById("participant-list");l.innerHTML="";d.participants.forEach(p=>{const e=document.createElement("div");e.className="participant";e.setAttribute("data-state",p.state);const lb=sl[p.state]||p.state;const ic=\x27<svg width="12" height="12"><use href="#ico-\x27+p.state+\x27"/></svg>\x27;let dt=\x27<span class="detail-label">Summary</span>\x27+esc(p.summary);if(p.blocker)dt+=\x27<span class="detail-label">Blocker</span><span class="detail-blocker">\x27+esc(p.blocker)+\x27</span>\x27;if(p.next)dt+=\x27<span class="detail-label">Next action</span><span class="detail-next">\x27+esc(p.next)+\x27</span>\x27;dt+=\x27<span class="detail-label">Resume</span><span class="detail-resume">\x27+esc(p.tool)+" in "+esc(p.terminal)+\x27</span>\x27;e.innerHTML=\x27<div class="participant-header"><span class="participant-name">\x27+esc(p.name)+\x27</span><span class="state-chip state-\x27+p.state+\x27">\x27+ic+lb+\x27</span></div><div class="participant-detail">\x27+dt+\x27</div>\x27;e.onclick=()=>{const dd=e.querySelector(".participant-detail");dd.style.display=dd.style.display==="block"?"none":"block"};l.appendChild(e)})}}catch(e){}},3000)</script></body>|' "$html_path_legacy"
                fi

                serve_dir="$camp_d"
            fi

            info "camp serving at http://localhost:${port}"
            printf "  serve dir: %s\n" "$serve_dir"
            printf "  press ctrl-c to stop\n\n"

            # Open browser
            camp_open_browser "http://localhost:${port}" 2>/dev/null || true

            # Watch for state changes and regenerate
            if [[ $legacy -eq 0 && -n "$_phaser_dist_s" ]]; then
                # Phaser: refresh camp.json in the serve dir every 3 seconds
                (
                    while true; do
                        sleep 3
                        cmd_export > /dev/null 2>&1 || true
                        cp "$camp_d/camp.json" "$serve_dir/camp.json" 2>/dev/null || true
                    done
                ) &
            else
                # Legacy: refresh camp-state.json
                (
                    while true; do
                        sleep 3
                        _camp_write_json "$project" "$camp_d/camp-state.json" 2>/dev/null || true
                    done
                ) &
            fi
            local watch_pid=$!
            trap "kill $watch_pid 2>/dev/null; exit 0" INT TERM

            # Serve via python
            if command -v python3 >/dev/null 2>&1; then
                python3 -m http.server "$port" --directory "$serve_dir" 2>/dev/null
            elif command -v python >/dev/null 2>&1; then
                cd "$serve_dir" && python -m SimpleHTTPServer "$port" 2>/dev/null
            else
                kill $watch_pid 2>/dev/null || true
                fail "python not found — needed for camp serve" "Install python3 or open the HTML directly: $serve_dir/index.html"
            fi
            ;;
        overview)
            camp_overview_print "$project"
            ;;
        mission)
            local action="${1:-}"
            shift || true
            # Interactive mission input when no args
            if [[ -z "$action" ]] && [[ -t 0 ]]; then
                printf '\n  \033[33m◎\033[0m  지금 뭘 만들고 있나요?\n'
                printf '     \033[2m미션을 한 문장으로 적어보세요.\033[0m\n\n'
                printf '  > '
                local input_title=""
                read -r input_title
                if [[ -n "$input_title" ]]; then
                    camp_set_mission "$project" "$input_title" "" "" ""
                    info "camp mission updated"
                    printf '     \033[2m좋아요! 캠프파이어에 불이 붙었어요.\033[0m\n\n'
                fi
                return 0
            fi
            [[ "$action" == "set" ]] || fail "usage: campsite camp mission set <title> [--summary=...] [--state=...] [--next-action=...]"

            local title="${1:-}"
            shift || true
            [[ -n "$title" ]] || fail "mission title required" "usage: campsite camp mission set <title> [--summary=...] [--state=...] [--next-action=...]"

            local summary="" state="" next_action=""
            for arg in "$@"; do
                case "$arg" in
                    --summary=*) summary="${arg#--summary=}" ;;
                    --state=*) state="${arg#--state=}" ;;
                    --next-action=*) next_action="${arg#--next-action=}" ;;
                    *) fail "unknown flag for campsite camp mission set: $arg" ;;
                esac
            done

            camp_set_mission "$project" "$title" "$summary" "$state" "$next_action"
            info "camp mission updated"
            ;;
        participant)
            local action="${1:-}"
            shift || true
            case "$action" in
                enter)
                    local participant_id="${1:-}"
                    shift || true
                    [[ -n "$participant_id" ]] || fail "participant id required" "usage: campsite camp participant enter <id> [--name=...] [--type=...] [--tool=...] [--terminal=...] [--state=...] [--summary=...] [--next-action=...] [--priority=N]"

                    local name="$participant_id" ptype="agent" tool="" terminal="" fire_state="bulssi" summary="" next_action="" priority="50"
                    for arg in "$@"; do
                        case "$arg" in
                            --name=*) name="${arg#--name=}" ;;
                            --type=*) ptype="${arg#--type=}" ;;
                            --tool=*) tool="${arg#--tool=}" ;;
                            --terminal=*) terminal="${arg#--terminal=}" ;;
                            --state=*) fire_state="${arg#--state=}" ;;
                            --summary=*) summary="${arg#--summary=}" ;;
                            --next-action=*) next_action="${arg#--next-action=}" ;;
                            --priority=*) priority="${arg#--priority=}" ;;
                            *) fail "unknown flag for campsite camp participant enter: $arg" ;;
                        esac
                    done

                    camp_participant_upsert "$project" "$participant_id" "$name" "$ptype" "$tool" "$terminal" "$fire_state" "$summary" "" "$next_action" "$priority"
                    camp_event_append "$project" "$participant_id" "" "$fire_state" "${summary:-Entered the camp.}"
                    info "camp participant entered → $participant_id"
                    ;;
                update)
                    local participant_id="${1:-}"
                    shift || true
                    [[ -n "$participant_id" ]] || fail "participant id required" "usage: campsite camp participant update <id> [--name=...] [--type=...] [--tool=...] [--terminal=...] [--state=...] [--summary=...] [--blocker=...] [--next-action=...] [--priority=N]"

                    local existing
                    existing="$(camp_participant_get "$project" "$participant_id")"
                    [[ -n "$existing" ]] || fail "unknown participant: $participant_id" "Run 'campsite camp participant enter $participant_id ...' first."

                    IFS=$'\t' read -r _id name ptype tool terminal fire_state summary blocker next_action _last_updated priority <<< "$existing"
                    local old_state="$fire_state"

                    for arg in "$@"; do
                        case "$arg" in
                            --name=*) name="${arg#--name=}" ;;
                            --type=*) ptype="${arg#--type=}" ;;
                            --tool=*) tool="${arg#--tool=}" ;;
                            --terminal=*) terminal="${arg#--terminal=}" ;;
                            --state=*) fire_state="${arg#--state=}" ;;
                            --summary=*) summary="${arg#--summary=}" ;;
                            --blocker=*) blocker="${arg#--blocker=}" ;;
                            --next-action=*) next_action="${arg#--next-action=}" ;;
                            --priority=*) priority="${arg#--priority=}" ;;
                            *) fail "unknown flag for campsite camp participant update: $arg" ;;
                        esac
                    done

                    camp_participant_upsert "$project" "$participant_id" "$name" "$ptype" "$tool" "$terminal" "$fire_state" "$summary" "$blocker" "$next_action" "$priority"
                    camp_event_append "$project" "$participant_id" "$old_state" "$fire_state" "${summary:-Updated participant state.}"
                    info "camp participant updated → $participant_id"
                    ;;
                *)
                    fail "usage: campsite camp participant <enter|update> ..."
                    ;;
            esac
            ;;
        "")
            fail "usage: campsite camp <render|serve|overview|mission|participant> ..."
            ;;
        *)
            # Backward-compatible flag-only usage maps to render.
            set -- "$subcommand" "$@"
            local no_open=0
            local print_path=0
            local legacy=0
            for arg in "$@"; do
                case "$arg" in
                    --no-open)    no_open=1 ;;
                    --print-path) print_path=1 ;;
                    --legacy)     legacy=1 ;;
                    *) fail "unknown camp command: $subcommand" "Valid commands: render, serve, overview, mission, participant" ;;
                esac
            done

            local html_path
            local _phaser_dist_fb
            _phaser_dist_fb="$(camp_phaser_dist_dir 2>/dev/null)" || _phaser_dist_fb=""
            if [[ $legacy -eq 0 && -n "$_phaser_dist_fb" ]]; then
                if ! html_path="$(camp_render_phaser "$project" 2>&1)"; then
                    warn "Phaser render failed — falling back to legacy renderer"
                    html_path="$(camp_render "$project")"
                fi
            else
                html_path="$(camp_render "$project")"
            fi

            if [[ $print_path -eq 1 ]]; then
                printf '%s\n' "$html_path"
                return 0
            fi

            info "camp rendered → $html_path"
            if [[ $no_open -eq 1 ]]; then
                return 0
            fi

            if camp_open_browser "$html_path"; then
                info "opened in browser"
            else
                warn "could not open a browser automatically"
                printf '%s\n' "$html_path"
            fi
            ;;
    esac
}

# --- campsite export [--json] ---
cmd_export() {
    local project
    project="$(detect_project)"

    local campsite_dir camp_d
    campsite_dir="$(project_campsite_dir "$project")"
    camp_d="$(camp_dir "$project")"

    # ── mission.title ─────────────────────────────────────────────────────────
    local mission_title=""
    local mission_file="$camp_d/mission.meta"
    if [[ -f "$mission_file" ]]; then
        mission_title="$(camp_field_get "$mission_file" "title")"
    fi
    [[ -n "$mission_title" ]] || mission_title="(no mission set)"

    # ── fire_state (derived from real signals) ──────────────────────────────
    local fire_state
    fire_state="$(firestate_derive "$project" 2>/dev/null || echo "bulssi")"
    local fire_label
    fire_label="$(firestate_label_ko "$fire_state")"

    # ── animal (from .campsite/project.meta, key animal=) ─────────────────────
    local animal="fox"
    local project_meta_file="$campsite_dir/project.meta"
    if [[ -f "$project_meta_file" ]]; then
        local raw_animal
        raw_animal="$(grep '^animal=' "$project_meta_file" 2>/dev/null | head -1 | sed 's/^animal=//' | tr -d '[:space:]')"
        [[ -n "$raw_animal" ]] && animal="$raw_animal"
    fi

    # ── last_activity (mtime of last events.tsv row) ─────────────────────────
    local last_activity=""
    local events_file="$camp_d/events.tsv"
    if [[ -f "$events_file" ]]; then
        # The first field of non-header rows is the ISO timestamp.
        last_activity="$(awk -F'\t' 'NR > 1 && $1 != "" { ts = $1 } END { print ts }' "$events_file" 2>/dev/null || true)"
    fi
    [[ -n "$last_activity" ]] || last_activity="$(now_iso)"

    # ── participant_count ─────────────────────────────────────────────────────
    local participant_count=0
    local participants_file="$camp_d/participants.tsv"
    if [[ -f "$participants_file" ]]; then
        participant_count="$(awk 'NR > 1 { count++ } END { print count + 0 }' "$participants_file" 2>/dev/null || echo 0)"
    fi

    # ── last_session ──────────────────────────────────────────────────────────
    local last_session=""
    local last_session_file="$camp_d/last-session"
    if [[ -f "$last_session_file" ]]; then
        last_session="$(tr -d '[:space:]' < "$last_session_file" 2>/dev/null || true)"
    fi
    [[ -n "$last_session" ]] || last_session="$(now_iso)"

    # ── JSON escape helper ────────────────────────────────────────────────────
    _json_esc() {
        printf '%s' "$1" \
            | sed \
                -e 's/\\/\\\\/g' \
                -e 's/"/\\"/g' \
                -e 's/	/\\t/g'
    }

    # ── project name ─────────────────────────────────────────────────────────
    local project_name
    project_name="$(basename "$project")"

    # ── next_action ──────────────────────────────────────────────────────────
    local next_action=""
    if [[ -f "$mission_file" ]]; then
        next_action="$(camp_field_get "$mission_file" "next-action")"
    fi
    [[ -n "$next_action" ]] || next_action="$(field_value "$project/handoff.md" "task" 2>/dev/null || echo "")"

    # ── Build participants JSON array (from agent sessions) ──────────────────
    local participants_json="[]"
    local active_list
    active_list="$(agent_list_active "$project" 2>/dev/null || true)"
    if [[ -n "$active_list" ]]; then
        local parr="["
        local pfirst=1
        while IFS=$'\t' read -r sid sname sstarted; do
            [[ -z "$sid" ]] && continue
            [[ $pfirst -eq 0 ]] && parr="$parr,"
            parr="$parr{\"name\":\"$(_json_esc "$sname")\",\"status\":\"active\",\"startedAt\":\"$(_json_esc "$sstarted")\"}"
            pfirst=0
        done <<< "$active_list"
        parr="$parr]"
        participants_json="$parr"
    fi

    # Also include recently finished participants from camp participants.tsv
    if [[ "$participants_json" == "[]" ]] && [[ -f "$participants_file" ]]; then
        local camp_parr="["
        local cpfirst=1
        while IFS=$'\t' read -r pid pname ptype ptool pterminal pfire psummary pblocker pnext plast pprio; do
            [[ "$pid" == "id" ]] && continue
            [[ -z "$pid" ]] && continue
            [[ $cpfirst -eq 0 ]] && camp_parr="$camp_parr,"
            local pstatus="ended"
            [[ "$pfire" == "modakbul" || "$pfire" == "bulssi" ]] && pstatus="active"
            [[ "$pfire" == "yeongi" ]] && pstatus="error"
            camp_parr="$camp_parr{\"name\":\"$(_json_esc "$pname")\",\"status\":\"$pstatus\"}"
            cpfirst=0
        done < "$participants_file"
        camp_parr="$camp_parr]"
        participants_json="$camp_parr"
    fi

    # ── Build events JSON array (from collector signals) ─────────────────────
    local events_json="[]"
    local signals_events_file
    signals_events_file="$(_collector_events_path "$project" 2>/dev/null || echo "")"

    # Try collector events first (real data), fall back to camp events
    local events_source=""
    if [[ -n "$signals_events_file" && -f "$signals_events_file" ]]; then
        events_source="$signals_events_file"
    elif [[ -f "$events_file" ]]; then
        events_source="$events_file"
    fi

    if [[ -n "$events_source" ]]; then
        local earr="["
        local efirst=1
        # Read last 5 events
        local elines
        elines="$(awk -F'\t' 'NR > 1 && NF >= 3' "$events_source" 2>/dev/null | tail -5)"
        while IFS=$'\t' read -r ets etype edesc esource; do
            [[ -z "$ets" ]] && continue
            [[ $efirst -eq 0 ]] && earr="$earr,"
            earr="$earr{\"timestamp\":\"$(_json_esc "$ets")\",\"type\":\"$(_json_esc "${etype:-event}")\",\"description\":\"$(_json_esc "${edesc:-}")\",\"source\":\"$(_json_esc "${esource:-system}")\"}"
            efirst=0
        done <<< "$elines"
        earr="$earr]"
        events_json="$earr"
    fi

    # ── Build events_summary (string array for backward compat) ──────────────
    local events_summary_json="[]"
    if [[ -n "$events_source" ]]; then
        local sarr="["
        local sfirst=1
        local slines
        slines="$(awk -F'\t' 'NR > 1 && NF >= 3 { print $3 }' "$events_source" 2>/dev/null | tail -3)"
        while IFS= read -r sline; do
            [[ -z "$sline" ]] && continue
            [[ $sfirst -eq 0 ]] && sarr="$sarr,"
            sarr="$sarr\"$(_json_esc "$sline")\""
            sfirst=0
        done <<< "$slines"
        sarr="$sarr]"
        events_summary_json="$sarr"
    fi

    # ── git summary ──────────────────────────────────────────────────────────
    local git_branch="" git_recent_commits=0 git_files_changed=0 git_insertions=0 git_deletions=0
    if git -C "$project" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        git_branch="$(git -C "$project" branch --show-current 2>/dev/null || echo "")"
        git_recent_commits="$(git -C "$project" log --oneline --since='24 hours ago' 2>/dev/null | wc -l | tr -d ' ')"
        local gstat
        gstat="$(git -C "$project" diff --stat 2>/dev/null | tail -1)"
        if [[ -n "$gstat" ]]; then
            git_files_changed="$(printf '%s' "$gstat" | sed -n 's/[[:space:]]*\([0-9][0-9]*\) file.*/\1/p' || echo 0)"
            git_insertions="$(printf '%s' "$gstat" | sed -n 's/.*\([0-9][0-9]*\) insertion.*/\1/p' || echo 0)"
            git_deletions="$(printf '%s' "$gstat" | sed -n 's/.*\([0-9][0-9]*\) deletion.*/\1/p' || echo 0)"
        fi
    fi
    [[ -n "$git_files_changed" ]] || git_files_changed=0
    [[ -n "$git_insertions" ]] || git_insertions=0
    [[ -n "$git_deletions" ]] || git_deletions=0
    [[ -n "$git_recent_commits" ]] || git_recent_commits=0

    # ── recovery (absence summary) ───────────────────────────────────────────
    local recovery_json=""
    recovery_json="$(collector_absence_summary "$project" 2>/dev/null || echo "")"

    # ── Assemble final JSON ───────────────────────────────────────────────────
    local recovery_field=""
    if [[ -n "$recovery_json" ]]; then
        recovery_field="$(printf ',\n  "recovery": %s' "$recovery_json")"
    fi

    local json
    json="$(printf '{
  "mission": {
    "title": "%s",
    "status": "active"
  },
  "fireState": "%s",
  "fireLabel": "%s",
  "nextAction": "%s",
  "projects": [
    {
      "name": "%s",
      "animal": "%s",
      "fire_state": "%s",
      "last_activity": "%s",
      "participant_count": %s
    }
  ],
  "participants": %s,
  "events": %s,
  "events_summary": %s,
  "last_session": "%s",
  "lastActivity": "%s",
  "gitSummary": {
    "branch": "%s",
    "recentCommits": %s,
    "filesChanged": %s,
    "insertions": %s,
    "deletions": %s
  }%s
}' \
        "$(_json_esc "$mission_title")" \
        "$(_json_esc "$fire_state")" \
        "$(_json_esc "$fire_label")" \
        "$(_json_esc "$next_action")" \
        "$(_json_esc "$project_name")" \
        "$(_json_esc "$animal")" \
        "$(_json_esc "$fire_state")" \
        "$(_json_esc "$last_activity")" \
        "$participant_count" \
        "$participants_json" \
        "$events_json" \
        "$events_summary_json" \
        "$(_json_esc "$last_session")" \
        "$(_json_esc "$last_activity")" \
        "$(_json_esc "$git_branch")" \
        "$git_recent_commits" \
        "$git_files_changed" \
        "$git_insertions" \
        "$git_deletions" \
        "$recovery_field")"

    # ── Write to camp.json for Phaser client ─────────────────────────────────
    local camp_json_path="$camp_d/camp.json"
    printf '%s\n' "$json" > "$camp_json_path"

    # ── Print to stdout ───────────────────────────────────────────────────────
    printf '%s\n' "$json"
}

# --- campsite setup helpers ---

# Returns 0 if path looks like a project directory
_setup_is_project_dir() {
    local path="$1"
    [[ -f "$path/status.md" ]]    && return 0
    [[ -f "$path/handoff.md" ]]   && return 0
    [[ -d "$path/.git" ]]         && return 0
    [[ -f "$path/package.json" ]] && return 0
    [[ -f "$path/pyproject.toml" ]] && return 0
    [[ -f "$path/Cargo.toml" ]]   && return 0
    [[ -f "$path/go.mod" ]]       && return 0
    [[ -f "$path/README.md" ]]    && return 0
    return 1
}

# Infer path intent: "project" | "workspace" | "new-valid" | "new-invalid"
_setup_infer_type() {
    local path="$1"
    if [[ -d "$path" ]]; then
        if _setup_is_project_dir "$path"; then
            printf 'project'
        else
            printf 'workspace'
        fi
    elif [[ -d "$(dirname "$path")" ]]; then
        printf 'new-valid'
    else
        printf 'new-invalid'
    fi
}

# Normalize any path input to absolute (handles ~, ., .., relative)
_setup_normalize_path() {
    local input="$1"
    input="${input/#\~/$HOME}"
    if [[ "$input" = "." ]]; then
        pwd; return 0
    fi
    if [[ "$input" != /* ]]; then
        local resolved
        resolved="$(cd "$input" 2>/dev/null && pwd)" \
            || resolved="$(pwd)/$input"
        printf '%s' "$resolved"
    else
        printf '%s' "$input"
    fi
}

# --- campsite setup — intent-absorbing bootstrap ---
cmd_setup() {
    local here=0
    [[ "${1:-}" == "--here" ]] && here=1

    printf '\n'
    printf "  ${_C_BOLD:-}campsite setup${_C_RESET:-}\n\n"

    # --- Get path input ---
    local raw_path
    if [[ $here -eq 1 ]]; then
        raw_path="$(pwd)"
        printf "  Using current folder:\n"
        printf "    ${_C_BOLD:-}%s${_C_RESET:-}\n\n" "$raw_path"
    else
        local default_path="${CAMPSITE_WORKSPACE:-$HOME/projects}"
        printf "  Enter a project or workspace path:\n"
        printf "  ${_C_DIM:-}(project folder, workspace root, or a new path)${_C_RESET:-}\n\n"
        printf "  path ${_C_DIM:-}[%s]${_C_RESET:-}: " "$default_path"
        read -r raw_path
        [[ -z "$raw_path" ]] && raw_path="$default_path"
    fi

    # --- Normalize ---
    local abs_path
    abs_path="$(_setup_normalize_path "$raw_path")"
    printf '\n'

    # --- Infer intent (loop handles new-invalid fallback without re-prompting) ---
    local path_type
    path_type="$(_setup_infer_type "$abs_path")"

    # Resolve new-invalid once before branching
    if [[ "$path_type" == "new-invalid" ]]; then
        printf "  I could not use that path — its parent does not exist:\n"
        printf "    ${_C_DIM:-}%s${_C_RESET:-}\n\n" "$(dirname "$abs_path")"
        printf "  Try one of these instead:\n"
        printf "    1) Use current folder: %s\n" "$(pwd)"
        printf "    2) Use home projects:  %s\n" "$HOME/projects"
        printf "    3) Enter another path\n"
        printf '\n  Choice [1]: '
        read -r choice
        case "${choice:-1}" in
            2) abs_path="$HOME/projects"; mkdir -p "$abs_path" ;;
            3) printf '  Path: '; read -r abs_path
               abs_path="$(_setup_normalize_path "$abs_path")" ;;
            *) abs_path="$(pwd)" ;;
        esac
        printf '\n'
        path_type="$(_setup_infer_type "$abs_path")"
    fi

    local ws_path="" proj_path="" do_init=0

    case "$path_type" in

        project)
            ws_path="$(dirname "$abs_path")"
            proj_path="$abs_path"
            printf "  That looks like a project folder:\n"
            printf "    ${_C_BOLD:-}%s${_C_RESET:-}\n\n" "$proj_path"
            printf "  Suggested workspace (parent):\n"
            printf "    ${_C_BOLD:-}%s${_C_RESET:-}\n\n" "$ws_path"
            printf "  Project   : %s\n" "$proj_path"
            printf "  Workspace : %s\n" "$ws_path"
            printf '\n'
            if ! ui_confirm "Use this setup?"; then
                printf '\n'
                printf "  Enter workspace path manually: "
                read -r ws_path
                ws_path="$(_setup_normalize_path "$ws_path")"
                mkdir -p "$ws_path"
            fi
            ;;

        workspace)
            ws_path="$abs_path"
            printf "  Workspace detected:\n"
            printf "    ${_C_BOLD:-}%s${_C_RESET:-}\n\n" "$ws_path"
            if ui_confirm "Initialize a new project inside this workspace?"; then
                do_init=1
                printf "  Project name: "
                read -r proj_name
                [[ -z "$proj_name" ]] && proj_name="my-project"
                proj_path="$ws_path/$proj_name"
            fi
            ;;

        new-valid)
            ws_path="$(dirname "$abs_path")"
            proj_path="$abs_path"
            printf "  That folder does not exist yet:\n"
            printf "    ${_C_BOLD:-}%s${_C_RESET:-}\n\n" "$abs_path"
            printf "  Suggested workspace:\n"
            printf "    ${_C_BOLD:-}%s${_C_RESET:-}\n\n" "$ws_path"
            printf '\n'
            if ui_confirm "Create it as a new project?"; then
                do_init=1
                mkdir -p "$abs_path"
            else
                printf '\n  Aborting setup.\n\n'
                return 0
            fi
            ;;

        *)
            # Still invalid after one correction — fall back to current dir
            abs_path="$(pwd)"
            ws_path="$abs_path"
            printf "  Using current folder as workspace:\n"
            printf "    ${_C_BOLD:-}%s${_C_RESET:-}\n\n" "$ws_path"
            ;;
    esac

    # --- Apply workspace ---
    [[ -z "$ws_path" ]] && ws_path="$abs_path"
    mkdir -p "$ws_path"
    printf '\n'
    cmd_workspace_set "$ws_path"

    # --- Init project if requested ---
    if [[ $do_init -eq 1 && -n "$proj_path" ]]; then
        printf '\n'
        cmd_init "$proj_path"
    fi

    printf '\n'

    # --- Check agents ---
    local found_agents=0
    while IFS= read -r adapter_name; do
        local adapter_file cmd_bin
        adapter_file="$(_adapter_find "$adapter_name" 2>/dev/null)" || continue
        cmd_bin="$(field_value_plain "$adapter_file" "command")"
        if command -v "$cmd_bin" >/dev/null 2>&1; then
            printf "  ${_C_GREEN:-}✓${_C_RESET:-} %s\n" "$adapter_name"
            found_agents=$((found_agents + 1))
        fi
    done < <(adapter_list 2>/dev/null || true)
    [[ $found_agents -eq 0 ]] && \
        printf "  ${_C_DIM:-}No AI agents detected. Install claude, codex, or gemini to use campsite.${_C_RESET:-}\n"

    # --- Mark complete ---
    local global_dir
    global_dir="$(campsite_global_dir)"
    printf '%s\n' "$(now_iso)" > "$global_dir/setup-complete"

    # --- Success output ---
    printf '\n'
    printf "  ${_C_GREEN:-}✓${_C_RESET:-} Setup complete.\n\n"
    printf "  You can now resume this project from the same state across sessions.\n\n"
    [[ -n "$proj_path" ]] && printf "  Project   : %s\n" "$proj_path"
    printf "  Workspace : %s\n" "$ws_path"
    printf '\n'
    printf "  Next steps:\n"
    printf "    campsite sync\n"
    printf "    campsite peek\n"
    printf "    campsite save\n"
    printf '\n'
}

# --- campsite peek — view active session from another terminal ---
cmd_peek() {
    local live=0
    for arg in "$@"; do
        [[ "$arg" == "--live" ]] && live=1
    done

    local project
    project="$(detect_project)"
    local name
    name="$(basename "$project")"

    _peek_print() {
        local lock_file
        lock_file="$(lock_path "$project")"

        if [[ ! -f "$lock_file" ]]; then
            printf '\n'
            printf "  ${_C_DIM:-}%s${_C_RESET:-} — no active session\n\n" "$name"
            return 1
        fi

        local actor tool pid host started task terminal
        actor="$(field_value_plain "$lock_file" "actor" 2>/dev/null || echo "?")"
        tool="$(field_value_plain "$lock_file" "tool" 2>/dev/null || echo "?")"
        pid="$(field_value_plain "$lock_file" "pid" 2>/dev/null || echo "?")"
        host="$(field_value_plain "$lock_file" "host" 2>/dev/null || echo "?")"
        started="$(field_value_plain "$lock_file" "started-at" 2>/dev/null || echo "?")"
        task="$(field_value_plain "$lock_file" "task" 2>/dev/null || echo "?")"
        terminal="$(field_value_plain "$lock_file" "terminal" 2>/dev/null || echo "?")"

        # Elapsed time
        local elapsed_str="?"
        if [[ "$started" != "?" ]]; then
            local start_epoch now_epoch elapsed
            start_epoch="$(date -d "$started" +%s 2>/dev/null \
                || date -j -f '%Y-%m-%dT%H:%M:%SZ' "$started" +%s 2>/dev/null \
                || echo 0)"
            now_epoch="$(date +%s)"
            elapsed=$(( now_epoch - start_epoch ))
            if [[ $elapsed -lt 3600 ]]; then
                elapsed_str="${elapsed_str:+}$((elapsed / 60))m"
            else
                elapsed_str="$((elapsed / 3600))h $((elapsed % 3600 / 60))m"
            fi
        fi

        # PID alive check
        local pid_status
        if [[ "$pid" != "?" ]] && kill -0 "$pid" 2>/dev/null; then
            pid_status="${_C_GREEN:-}running${_C_RESET:-}"
        else
            pid_status="${_C_RED:-}dead${_C_RESET:-}"
        fi

        printf '\n'
        printf "  ${_C_BOLD:-}%s${_C_RESET:-} — active session\n\n" "$name"
        printf "  agent:     %s\n" "$tool"
        printf "  user:      %s\n" "$actor"
        printf "  device:    %s\n" "$host"
        printf "  terminal:  %s\n" "$terminal"
        printf "  started:   %s (%s)\n" "$started" "$elapsed_str"
        printf "  mission:   %s\n" "$task"
        printf "  pid:       %s (%b)\n" "$pid" "$pid_status"
        printf '\n'

        if [[ -f "$(camp_participants_path "$project")" ]]; then
            while IFS=$'\t' read -r label value; do
                case "$label" in
                    ACTIVE) printf "  working-now:      %s\n" "$value" ;;
                    WAITING) printf "  waiting-on-you:   %s\n" "$value" ;;
                    NEXT) printf "  next-move:        %s\n" "$value" ;;
                esac
            done < <(camp_overview_lines "$project")
            printf '\n'
        fi
    }

    if [[ $live -eq 1 ]]; then
        while true; do
            clear
            _peek_print || break
            sleep 5
        done
    else
        _peek_print
    fi
}

# --- campsite go [name|number] [--sync] — quick-jump to recent project ---
cmd_go() {
    local target="" do_sync=0
    for arg in "$@"; do
        case "$arg" in
            --sync) do_sync=1 ;;
            *) target="$arg" ;;
        esac
    done

    # Build MRU list
    local -a mru_names=()
    local -a mru_times=()
    while IFS=',' read -r pname ptime; do
        mru_names+=("$pname")
        mru_times+=("$ptime")
    done < <(history_mru_projects 10 2>/dev/null || true)

    if [[ ${#mru_names[@]} -eq 0 ]]; then
        fail "no project history yet" \
             "Run 'campsite sync' in a project first, or 'campsite setup'"
    fi

    local resolved_path=""

    if [[ -z "$target" ]]; then
        # Interactive: show MRU list
        printf '\n'
    printf "  ${_C_BOLD:-}Recent projects:${_C_RESET:-}\n"
        local idx=1
        for i in "${!mru_names[@]}"; do
            local rel_time=""
            [[ -n "${mru_times[$i]}" ]] && rel_time="$(_history_relative_time "${mru_times[$i]}" 2>/dev/null || echo "?")"
            printf "  ${_C_DIM:-}%2d${_C_RESET:-}  %-20s  (%s)\n" "$idx" "${mru_names[$i]}" "$rel_time"
            idx=$((idx + 1))
        done
        printf '\n'

        local selection
        selection="$(ui_select "project" "${#mru_names[@]}" "1")"
        target="${mru_names[$((selection - 1))]}"
    elif [[ "$target" =~ ^[0-9]+$ ]]; then
        # Numeric index into MRU
        if [[ "$target" -ge 1 && "$target" -le "${#mru_names[@]}" ]]; then
            target="${mru_names[$((target - 1))]}"
        else
            fail "invalid index: $target (have ${#mru_names[@]} projects)"
        fi
    fi

    # Resolve name to full path
    resolved_path="$(history_resolve_project_path "$target" 2>/dev/null)" || {
        # Try detect_project from name match
        fail "cannot find project: $target" \
             "Check workspace path with 'campsite dashboard'"
    }

    # If --sync requested, compile first
    if [[ $do_sync -eq 1 ]]; then
        (cd "$resolved_path" && cmd_sync)
    fi

    # Print path to stdout (shell wrapper does the cd)
    printf '%s' "$resolved_path"
}

# --- campsite workspace set <path> ---
cmd_workspace_set() {
    [[ $# -ge 1 ]] || fail "usage: campsite workspace set <path>"
    local ws_path
    ws_path="$(resolve_path "$1")"
    [[ -d "$ws_path" ]] || fail "directory not found: $ws_path"

    local global_dir
    global_dir="$(campsite_global_dir)"
    mkdir -p "$global_dir/user"

    local config_file="$global_dir/user/config.sh"

    if [[ -f "$config_file" ]] && grep -q 'CAMPSITE_WORKSPACE=' "$config_file"; then
        # Update existing (portable: no sed -i)
        _portable_sed_i "s|^.*CAMPSITE_WORKSPACE=.*|CAMPSITE_WORKSPACE=\"$ws_path\"|" "$config_file"
    else
        printf '\nCAMPSITE_WORKSPACE="%s"\n' "$ws_path" >> "$config_file"
    fi

    info "workspace set to: $ws_path"
}

# --- Deprecated command messages ---
_deprecated() {
    local old="$1" new="$2"
    warn "'campsite $old' is deprecated. Use: $new"
    exit 1
}

# ============================================================
# First-run guided flow for a new project
# ============================================================

first_run_flow() {
    local project_root="$PWD"
    local project_name
    project_name="$(basename "$project_root")"

    printf '\n'
    printf '  \033[33m◎\033[0m  이 프로젝트를 캠프에 등록할게요: %s\n' "$project_name"
    printf '\n'

    # 1. Auto-init the project
    cmd_init "$project_root"

    # 2. Auto-populate status.md from git state
    _first_run_populate_status "$project_root"

    # 3. Prompt for mission
    printf '\n'
    printf '  지금 이 프로젝트에서 하고 있는 일이 뭔가요?\n'
    printf '  > '
    local mission_title=""
    read -r mission_title
    if [[ -n "$mission_title" ]]; then
        camp_set_mission "$project_root" "$mission_title"
        info "mission set: $mission_title"
    fi

    # 4. Record first-run event
    collector_record_event "$project_root" "first_run" "Project $project_name registered in campsite" "user" 2>/dev/null || true

    # 5. Show status
    cmd_status

    printf '\n'
    printf '  \033[32m◎\033[0m  준비 완료! campsite 를 다시 실행하면 에이전트를 선택할 수 있어요.\n'
    printf '     campsite camp serve 로 대시보드를 열 수 있어요.\n'
    printf '\n'
}

_first_run_populate_status() {
    local project_root="$1"
    local status_file="$project_root/status.md"

    # Only populate if status.md is a template (contains "project-name" placeholder)
    [[ -f "$status_file" ]] || return 0
    grep -q 'project-name' "$status_file" 2>/dev/null || return 0

    local branch current_phase
    branch="$(git -C "$project_root" branch --show-current 2>/dev/null || echo "main")"
    current_phase="building"

    local recent_work=""
    if git -C "$project_root" log --oneline -5 2>/dev/null | head -5 > /dev/null 2>&1; then
        recent_work="$(git -C "$project_root" log --oneline -5 2>/dev/null | head -5)"
    fi

    local project_name
    project_name="$(basename "$project_root")"
    local today
    today="$(today_date)"

    cat > "$status_file" <<EOF
# Status — $project_name

- phase: $current_phase
- confidence: medium
- last-updated: $today
- last-agent: none
- last-device: $(detect_device 2>/dev/null || echo "unknown")
- branch: $branch

## Recent work

$(if [[ -n "$recent_work" ]]; then printf '%s' "$recent_work"; else printf 'No recent commits.'; fi)

## Current state

Project registered in campsite. Ready to start.
EOF
}

# ============================================================
# Main
# ============================================================

main() {
    case "${1:-}" in
        "")
            # First-run detection — friendly welcome
            if [[ ! -f "$(campsite_global_dir)/setup-complete" ]]; then
                printf '\n'
                printf '  \033[33m◎\033[0m  처음이시네요! 캠프를 만들어볼까요?\n'
                printf '     \033[2m어렵지 않아요. 1분이면 됩니다.\033[0m\n'
                printf '\n'
                cmd_setup "$@"
                return $?
            fi
            # Project-level first-run: auto-init if in a git repo without .campsite/
            if [[ ! -d ".campsite" ]] && git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
                first_run_flow
                return $?
            fi
            cmd_launcher
            ;;
        setup)
            shift; cmd_setup "$@"
            ;;
        init)
            shift; cmd_init "$@"
            ;;
        sync)
            shift; cmd_sync "$@"
            ;;
        save)
            shift; cmd_save "$@"
            ;;
        status)
            shift; cmd_status "$@"
            ;;
        peek)
            shift; cmd_peek "$@"
            ;;
        go)
            shift; cmd_go "$@"
            ;;
        validate)
            shift; cmd_validate "$@"
            ;;
        recover)
            shift; cmd_recover "$@"
            ;;
        dashboard)
            shift; cmd_dashboard "$@"
            ;;
        camp)
            shift; cmd_camp "$@"
            ;;
        export)
            shift
            # Accept optional --json flag (makes the intent explicit; behaviour is identical)
            for _exp_arg in "$@"; do
                case "$_exp_arg" in
                    --json) ;;
                    *) fail "unknown flag for campsite export: $_exp_arg" "Valid flags: --json" ;;
                esac
            done
            cmd_export
            ;;
        workspace)
            shift
            case "${1:-}" in
                set) shift; cmd_workspace_set "$@" ;;
                *) fail "usage: campsite workspace set <path>" ;;
            esac
            ;;
        --version|-v)
            cat "$CAMPSITE_ROOT/VERSION" 2>/dev/null \
                || cat "$CAMPSITE_ROOT/version" 2>/dev/null \
                || echo "dev"
            ;;
        help|-h|--help)
            usage
            ;;
        # Deprecated commands
        enter|start)   _deprecated "$1" "campsite (launcher)" ;;
        leave|finish)  _deprecated "$1" "campsite save" ;;
        resume|open)   _deprecated "$1" "campsite status" ;;
        handoff)       _deprecated "$1" "campsite status" ;;
        context)       _deprecated "$1" "campsite sync" ;;
        summary)       _deprecated "$1" "campsite dashboard" ;;
        claude|codex|gemini|openclaw)
            _deprecated "$1" "campsite (launcher, then select $1)"
            ;;
        *)
            fail "unknown command: $1" "Run 'campsite help' for usage."
            ;;
    esac
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
